{
    "compilerOptions": {
        "lib": [
            "ES2020"
        ],
        "noEmitHelpers": true,
        "module": "ES2020",
        "outDir": "out",
        "target": "ES2020",
        "types": [
            "./types/Actions.d.ts"
        ],
        "esModuleInterop": false,
        "removeComments": true,
        "declaration": false        
    },
    "include": [
        "src/ActionHelpers.ts"
    ],
    "exclude": [
        "node_modules"
    ],
    "typedocOptions": {
        "entryPoints": [
            "types/Actions.d.ts",
            "src/ActionHelpers.ts"
        ],
        "out": "docs",
        "excludePrivate": true
    }
}