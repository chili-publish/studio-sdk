{
    "name": "actions",
    "version": "1.46.0-alpha.3",
    "apiVersion": "1.0",
    "license": "MIT",
    "scripts": {
        "build": "yarn tsc && yarn tsc -p tsconfig.types.json && cp training.json out/training.json && cp types/Actions.d.ts out/Actions.d.ts && node scripts/actionhelpers-monaco.mjs && node scripts/compress.mjs",
        "build-docs-md": "npx typedoc --plugin typedoc-plugin-markdown --out ./docs/md",
        "build-docs-html": "npx typedoc --out ./docs/html --readme ./src/README_HTML.md"
    },
    "devDependencies": {
        "dotenv": "^16.3.1",
        "find-root": "^1.1.0",
        "fs-extra": "^11.1.1",
        "prettier": "^3.0.3",
        "terser": "^5.19.4",
        "typedoc": "^0.27.9",
        "typedoc-plugin-markdown": "4.4.0",
        "typescript": "^5.2.2"
    }
}